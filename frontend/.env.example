# Copy this file to .env and fill in real values for local development.

VITE_API_URL=/api

# Microsoft Entra ID SSO (MSAL.js) — see src/auth/msalConfig.js.
# VITE_USE_MOCK_SSO=true (default) keeps the dev-only email picker on the
# Login screen working without any Azure tenant. Once you've registered an
# app in your Azure tenant, set these and flip VITE_USE_MOCK_SSO to false —
# it must match the backend's USE_MOCK_SSO / ENTRA_TENANT_ID / ENTRA_CLIENT_ID.
VITE_USE_MOCK_SSO=true
VITE_ENTRA_TENANT_ID=
VITE_ENTRA_CLIENT_ID=
