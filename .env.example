# Copy to .env in the project root (same folder as docker-compose.yml).
# docker-compose.yml reads these for the backend container.
# Leave any of these blank and the corresponding feature just runs in its
# already-documented fallback mode (mock SSO / no email sent / keyword-search
# chatbot fallback if ChromaDB isn't reachable).

JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Microsoft Entra ID SSO — see backend/.env.example for details.
USE_MOCK_SSO=true
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_HR_ADMIN_GROUP_ID=
ENTRA_IT_ADMIN_GROUP_ID=

GEMINI_API_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
