# Copy this file to .env and fill in real values for local development.

# PostgreSQL connection
DATABASE_URL=postgresql+psycopg2://hrflow_user:hrflow_pass@localhost:5432/hrflow

# JWT secret (app-issued session token) — generate a real random value: openssl rand -hex 32
JWT_SECRET=dev-only-change-me-before-deploying
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=480

# CORS origins (your Vite dev server)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Microsoft Entra ID SSO ───────────────────────────────────────────────────
# USE_MOCK_SSO=true (default) keeps the dev-only email picker on the Login
# screen working without any Azure tenant. Once you've registered an app in
# your Azure tenant (Entra ID -> App registrations), set these and flip
# USE_MOCK_SSO to false — see app/security.py and app/routers/auth.py.
USE_MOCK_SSO=true
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
# Entra ID security-group Object IDs for the SHARED HR Admin / IT Admin
# accounts (see employees.is_shared_admin in db/schema.sql) — any real staff
# member who is a member of these groups is signed into that shared account,
# rather than the account being tied to one named person.
ENTRA_HR_ADMIN_GROUP_ID=
ENTRA_IT_ADMIN_GROUP_ID=

# Gemini API key (optional — chatbot falls back to keyword search without it)
GEMINI_API_KEY=
# If chatbot requests fail with a 404 ("model no longer available to new
# users") or a quota error showing "limit: 0" for a specific model, your
# Google account's free tier may not have that exact dated model enabled.
# gemini-flash-latest is Google's self-updating alias to their current
# recommended free-tier Flash model, so it's the safest default — only
# change this if you have a specific reason to pin an exact model version.
GEMINI_MODEL_NAME=gemini-flash-latest

# ── RAG pipeline (ChromaDB + LangChain + Sentence-Transformers) ──────────────
# Matches the `chromadb` service in docker-compose.yml. Only needs changing
# if you run the backend outside docker compose.
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=hr_policy_docs
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# ── Email notifications (optional) ───────────────────────────────────────────
# Leave SMTP_HOST blank to disable email — app works fully without it.
# For Gmail:
#   1. Enable 2-step verification: myaccount.google.com → Security
#   2. Generate App Password: Security → App passwords → Mail → generate
#   3. Use the 16-character code as SMTP_PASSWORD (NOT your real Gmail password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
SMTP_FROM_NAME=HRFlow Portal
